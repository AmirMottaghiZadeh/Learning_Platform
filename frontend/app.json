{
  "expo": {
    "name": "Pharmexa",
    "slug": "pharmexa-learning",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "Pharmexa",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#031820"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#031820"
      }
    },
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "name": "Pharmexa",
      "shortName": "Pharmexa",
      "description": "Mobile-first adaptive learning dashboard for daily quizzes, mistakes, and flashcard review.",
      "themeColor": "#031820",
      "backgroundColor": "#031820",
      "lang": "en"
    },
    "plugins": [],
    "experiments": {
      "typedRoutes": false
    }
  }
}
