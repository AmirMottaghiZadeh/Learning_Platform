SECRET_KEY=change-me
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.local
ENVIRONMENT=local
APP_VERSION=0.1.0
RELEASE_SHA=local
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/pharmexa
LOG_LEVEL=INFO
LOG_FORMAT=plain
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
LEARNING_PRODUCT_ADAPTER=apps.drugs.learning_adapter.PharmexaLearningAdapter
AI_DATA_PIPELINE_PROVIDER=rules
AUTH_TOKEN_TTL_HOURS=24
PASSWORD_RESET_TIMEOUT=86400
PASSWORD_RESET_FRONTEND_URL=http://localhost:8081
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@pharmexa.local
CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
CACHE_LOCATION=pharmexa-default-cache
DRF_ANON_THROTTLE_RATE=1000/hour
DRF_AUTH_LOGIN_THROTTLE_RATE=5/min
DRF_AUTH_REGISTER_THROTTLE_RATE=5/hour
DRF_AUTH_PASSWORD_RESET_REQUEST_THROTTLE_RATE=3/hour
DRF_AUTH_PASSWORD_RESET_CONFIRM_THROTTLE_RATE=5/hour
